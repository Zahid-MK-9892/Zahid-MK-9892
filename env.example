# ── FRIDAY Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys
# Never share or commit your .env file!

# Anthropic (FRIDAY's AI brain)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Alpaca (Paper stock trading)
# Get from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # Paper trading URL — safe!

# Binance Testnet (Paper crypto trading)
# Get from: https://testnet.binance.vision → Log in with GitHub → Generate Keys
BINANCE_API_KEY=your_binance_testnet_key_here
BINANCE_SECRET_KEY=your_binance_testnet_secret_here
BINANCE_TESTNET=true

# NewsAPI (Market news)
# Get from: https://newsapi.org → free tier is fine
NEWS_API_KEY=your_newsapi_key_here

# ── Trading Config ─────────────────────────────────────────────────────────────
# Set to true to run without any real/paper API calls (pure simulation)
MOCK_MODE=true

# Capital allocated to each trade (USD)
CAPITAL_PER_TRADE=500

# Max % of capital to risk per trade (e.g. 2 = 2%)
MAX_RISK_PERCENT=2

# Stop loss % below entry (e.g. 5 = 5%)
STOP_LOSS_PERCENT=5

# Take profit % above entry (e.g. 10 = 10%)
TAKE_PROFIT_PERCENT=10

# Telegram Bot (free alerts — no credit card needed)
# Setup: Open Telegram → @BotFather → /newbot → get TOKEN
#        Then message @userinfobot → get your CHAT_ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here